# the-star-way sample.env
# 复制为 .env 或按需导入到当前 shell。不要提交真实密钥。

# ===== Backend =====
# 后端 API 端口，默认 3210。
PORT=3210

# GitHub Token，用于提高 GitHub API rate limit。
# 后端 /api/sync 优先读取请求 body 中的 token，其次读取此环境变量。
STARWAY_GITHUB_TOKEN=ghp_replace_with_your_github_token

# OpenAI-compatible AI Provider。
# 三项都填写后 AI 才会启用；留空则基础功能不受影响。
STARWAY_AI_BASE_URL=https://api.openai.com/v1
STARWAY_AI_API_KEY=sk-replace_with_your_ai_api_key
STARWAY_AI_MODEL=gpt-4.1-mini

# 预留：本地模型服务示例。
# STARWAY_AI_BASE_URL=http://127.0.0.1:11434/v1
# STARWAY_AI_API_KEY=ollama
# STARWAY_AI_MODEL=qwen2.5

# ===== Frontend =====
# 前端访问后端 API 的地址。
VITE_API_BASE=http://localhost:3210

# ===== Notes =====
# 当前 SQLite 默认路径：backend/data/starway.db。
# 当前浏览器设置页也支持保存 GitHub Token 到 localStorage。
